# Phase 17 — chained assignment, match guards, multiline collections

बताओ "== 1. chained assignment =="
अ है ब है स है 0
जाँचो अ बराबर 0, "chain अ गलत"
जाँचो ब बराबर 0, "chain ब गलत"
जाँचो स बराबर 0, "chain स गलत"
क है ख है 7 + 3
जाँचो क बराबर 10, "chain expr क गलत"
जाँचो ख बराबर 10, "chain expr ख गलत"

बताओ "== 2. chained reassign =="
प है 1
र है 2
प है र है 99
जाँचो प बराबर 99, "reassign प गलत"
जाँचो र बराबर 99, "reassign र गलत"

बताओ "== 3. multiline list =="
सूची है [
    1,
    2,
    3,
    4
]
जाँचो सूची.लम्बाई() बराबर 4, "multiline list लम्बाई गलत"
जाँचो सूची बराबर [1, 2, 3, 4], "multiline list मान गलत"

बताओ "== 4. multiline dict =="
कोश है {
    "नाम": "राम",
    "आयु": 30,
    "शहर": "दिल्ली"
}
जाँचो कोश.लम्बाई() बराबर 3, "multiline dict लम्बाई गलत"
जाँचो कोश["नाम"] बराबर "राम", "multiline dict मान गलत"

बताओ "== 5. multiline call =="
विधि जोड़_तीन(a, b, c):
    फल a + b + c
योग है जोड़_तीन(
    10,
    20,
    30
)
जाँचो योग बराबर 60, "multiline call गलत"

बताओ "== 6. match guard =="
विकल्प आकार:
    वृत्त(त्रिज्या)
    आयत(चौड़ाई, ऊंचाई)

विधि वर्णन(आ):
    मिलाओ आ:
        वृत्त(r) यदि r से अधिक 10:
            फल "बड़ा वृत्त"
        वृत्त(r):
            फल "छोटा वृत्त"
        आयत(w, h) यदि w बराबर h:
            फल "वर्ग"
        आयत(w, h):
            फल "आयत"

जाँचो वर्णन(आकार.वृत्त(20)) बराबर "बड़ा वृत्त", "guard बड़ा गलत"
जाँचो वर्णन(आकार.वृत्त(5)) बराबर "छोटा वृत्त", "guard छोटा गलत"
जाँचो वर्णन(आकार.आयत(4, 4)) बराबर "वर्ग", "guard वर्ग गलत"
जाँचो वर्णन(आकार.आयत(4, 8)) बराबर "आयत", "guard आयत गलत"

बताओ "== 7. wildcard guard =="
विधि जाँच(न):
    मिलाओ आकार.वृत्त(न):
        वृत्त(r) यदि r से कम 0:
            फल "ऋण"
        अन्यथा:
            फल "ठीक"
जाँचो जाँच(5) बराबर "ठीक", "wildcard guard गलत"

बताओ "== सम्पूर्ण =="
