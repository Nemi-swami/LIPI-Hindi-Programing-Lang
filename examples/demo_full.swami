# भारत बैंक — LIPI Full Demo
# Tests: arithmetic, strings, conditions, loops, functions, stdlib

आयात भारत.संख्या
आयात भारत.पहचान
आयात भारत.भुगतान

# ── विधियाँ (functions) ──────────────────────────────

विधि वर्गफल(अ):
    फल अ * अ

विधि घन(अ):
    फल अ * अ * अ

विधि क्षेत्रफल(लंबाई, चौड़ाई):
    फल लंबाई * चौड़ाई

विधि अधिकतम(अ, ब):
    यदि अ से अधिक ब:
        फल अ
    अन्यथा:
        फल ब

विधि न्यूनतम(अ, ब):
    यदि अ से कम ब:
        फल अ
    अन्यथा:
        फल ब

विधि साधारण_ब्याज(मूल, दर, समय):
    फल मूल * दर * समय / 100

विधि चक्रवृद्धि_अनुमान(राशि, दर):
    फल राशि + राशि * दर / 100

विधि श्रेणी(अंक):
    यदि अंक से अधिक 89:
        फल "A+"
    अन्यथा:
        फल "B या कम"

