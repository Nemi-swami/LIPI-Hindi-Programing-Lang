# ── 2. वाक्य (Strings) ───────────────────────────────
बताओ "── 2. वाक्य ──"
नाम है "अर्जुन"
शहर है "मुंबई"
बताओ "नमस्ते, " + नाम + "!"
बताओ "शहर: " + शहर
बताओ "खाता: " + नाम + " (" + शहर + ")"
बताओ ""

# ── 3. शर्त — if/else ────────────────────────────────
बताओ "── 3. शर्त ──"
शेष है 25000
यदि शेष से अधिक 100000:
    बताओ "प्लैटिनम खाता"
अन्यथा:
    यदि शेष से अधिक 10000:
        बताओ "सिल्वर खाता"
    अन्यथा:
        बताओ "बेसिक खाता"
बताओ ""

