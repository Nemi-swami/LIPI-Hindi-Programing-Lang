# Phase 17B — भारत.प्रतिमान (regex) test
आयात भारत.प्रतिमान

# ── 1. ढूंढो — first match ─────────────────────────────────────
जाँचो ढूंढो("\d+", "कमरा 42, मंज़िल 7") बराबर "42", "1a: digits"
जाँचो ढूंढो("[a-z]+@[a-z]+\.[a-z]+", "मेल: ram@example.com पर") बराबर "ram@example.com", "1b: email"
जाँचो ढूंढो("xyz", "कुछ नहीं") बराबर शून्य, "1c: no match → शून्य"
बताओ "1 ठीक: ढूंढो"

# ── 2. ढूंढो_स्थान — index ─────────────────────────────────────
जाँचो ढूंढो_स्थान("\d+", "अबक 99") बराबर 4, "2a: index"
जाँचो ढूंढो_स्थान("q", "अबक") बराबर -1, "2b: -1 when absent"
बताओ "2 ठीक: ढूंढो_स्थान"

# ── 3. ढूंढो_सब — all matches ──────────────────────────────────
जाँचो ढूंढो_सब("\d+", "1 और 22 और 333").मिलाओ(",") बराबर "1,22,333", "3a: findall"
जाँचो ढूंढो_सब("क+", "क कक स ककक").मिलाओ("|") बराबर "क|कक|ककक", "3b: Devanagari"
जाँचो ढूंढो_सब("x", "abc").लम्बाई() बराबर 0, "3c: empty list"
बताओ "3 ठीक: ढूंढो_सब"

# ── 4. मेल_है — full match ─────────────────────────────────────
जाँचो मेल_है("\d{4}", "2026") बराबर सत्य, "4a: full"
जाँचो मेल_है("\d{4}", "साल 2026") बराबर असत्य, "4b: partial ≠ full"
जाँचो मेल_है("[नम]मस्ते", "नमस्ते") बराबर सत्य, "4c: class"
बताओ "4 ठीक: मेल_है"

# ── 5. Quantifiers + anchors + alternation ────────────────────
जाँचो ढूंढो("^आ.*त$", "आयात") बराबर "आयात", "5a: anchors"
जाँचो ढूंढो("रा?म", "रम") बराबर "रम", "5b: optional"
जाँचो ढूंढो("(बिल्ली|कुत्ता)", "मेरा कुत्ता") बराबर "कुत्ता", "5c: alternation"
जाँचो ढूंढो("अ{2,3}", "अअअअ") बराबर "अअअ", "5d: greedy {2,3}"
जाँचो ढूंढो("अ{2,3}?", "अअअअ") बराबर "अअ", "5e: lazy {2,3}?"
जाँचो ढूंढो("<.+?>", "<a><b>") बराबर "<a>", "5f: lazy +?"
बताओ "5 ठीक: परिमाणक"

# ── 6. समूह — capture groups ───────────────────────────────────
भाग है समूह("(\d{2}):(\d{2})", "समय 14:35 पर")
जाँचो भाग[0] बराबर "14:35", "6a: full"
जाँचो भाग[1] बराबर "14", "6b: group 1"
जाँचो भाग[2] बराबर "35", "6c: group 2"
जाँचो समूह("(x)(y)", "ab").लम्बाई() बराबर 0, "6d: no match → []"
बताओ "6 ठीक: समूह"

# ── 7. बदलो_सब — replace with $N refs ──────────────────────────
जाँचो बदलो_सब("\d+", "#", "क 1 ख 22") बराबर "क # ख #", "7a: plain"
जाँचो बदलो_सब("(\w+)@(\w+)", "$2 का $1", "ram@gmail") बराबर "gmail का ram", "7b: $N refs"
जाँचो बदलो_सब("\s+", " ", "अ    ब  स") बराबर "अ ब स", "7c: whitespace squeeze"
जाँचो बदलो_सब("x", "$$", "axb") बराबर "a$b", "7d: $$ literal"
बताओ "7 ठीक: बदलो_सब"

# ── 8. विभाजित_सब — split ──────────────────────────────────────
जाँचो विभाजित_सब(",\s*", "अ, ब,स,  द").मिलाओ("|") बराबर "अ|ब|स|द", "8a: split"
जाँचो विभाजित_सब("\d", "अ1ब2स").लम्बाई() बराबर 3, "8b: count"
बताओ "8 ठीक: विभाजित_सब"

# ── 9. Errors are catchable ────────────────────────────────────
कोशिश:
    ढूंढो("(अधूरा", "पाठ")
    जाँचो असत्य, "9a: should have thrown"
पकड़ो त्रुटि:
    बताओ "9 ठीक: अमान्य प्रतिमान पकड़ा — " + त्रुटि

# ── 10. Unicode classes on Devanagari ─────────────────────────
जाँचो ढूंढो("\w+", "  नमस्ते!") बराबर "नमस्ते", "10a: \w covers Devanagari"
जाँचो बदलो_सब("[^\d]", "", "अ1ब2स3") बराबर "123", "10b: negated class"
बताओ "10 ठीक: Unicode"

बताओ "प्रतिमान: सभी परीक्षण सफल!"
