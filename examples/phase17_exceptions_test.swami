# Phase 17A — typed exceptions: फेंको + वर्ग X(त्रुटि) + typed पकड़ो

वर्ग जाल_त्रुटि(त्रुटि):
    विधि बनाओ(संदेश):
        यह.संदेश है संदेश

वर्ग समय_सीमा_त्रुटि(जाल_त्रुटि):
    विधि बनाओ(संदेश, सेकंड):
        यह.संदेश है संदेश
        यह.सेकंड है सेकंड

वर्ग गणना_त्रुटि(त्रुटि):
    विधि बनाओ(संदेश):
        यह.संदेश है संदेश

बताओ "== 1. फेंको + typed पकड़ो =="
कोशिश:
    फेंको जाल_त्रुटि("कनेक्शन विफल")
    बताओ "यहाँ नहीं पहुँचना चाहिए"
पकड़ो जाल_त्रुटि ई:
    बताओ "पकड़ा: " + ई.संदेश

बताओ "== 2. उप-वर्ग को मूल वर्ग का क्लॉज़ पकड़ता है =="
कोशिश:
    फेंको समय_सीमा_त्रुटि("बहुत धीमा", 30)
पकड़ो जाल_त्रुटि ई:
    बताओ "मूल वर्ग ने पकड़ा: " + ई.संदेश + " (" + ई.सेकंड + " से)"

बताओ "== 3. क्लॉज़ क्रम — विशेष पहले =="
कोशिश:
    फेंको समय_सीमा_त्रुटि("देर", 5)
पकड़ो समय_सीमा_त्रुटि ई:
    बताओ "विशेष क्लॉज़: " + ई.संदेश
पकड़ो जाल_त्रुटि ई:
    बताओ "गलत — सामान्य क्लॉज़ चला"

बताओ "== 4. बेमेल प्रकार बाहरी कोशिश तक जाता है =="
कोशिश:
    कोशिश:
        फेंको गणना_त्रुटि("भाग शून्य")
    पकड़ो जाल_त्रुटि ई:
        बताओ "गलत — जाल नहीं है"
पकड़ो गणना_त्रुटि ई:
    बताओ "बाहरी ने पकड़ा: " + ई.संदेश

बताओ "== 5. पुराना पकड़ो त्रुटि: — string त्रुटियाँ =="
कोशिश:
    क है पूर्णांक("abc")
पकड़ो त्रुटि:
    बताओ "वाक्य त्रुटि: " + त्रुटि

कोशिश:
    फेंको जाल_त्रुटि("कुछ")
पकड़ो त्रुटि:
    बताओ "कैच-ऑल ने instance पकड़ा: " + त्रुटि.संदेश

कोशिश:
    फेंको "सीधा वाक्य फेंका"
पकड़ो त्रुटि ई:
    बताओ "स्पष्ट चर: " + ई

कोशिश:
    फेंको "परीक्षा"
पकड़ो गलती:
    बताओ "पुराना रूप: " + गलती

बताओ "== 6. typed क्लॉज़ string को नहीं पकड़ता =="
कोशिश:
    फेंको "वाक्य"
पकड़ो जाल_त्रुटि ई:
    बताओ "गलत"
पकड़ो त्रुटि:
    बताओ "कैच-ऑल: " + त्रुटि

बताओ "== 7. कार्य से ऊपर फैलता है =="
विधि गहरा(न):
    यदि न बराबर 0:
        फेंको जाल_त्रुटि("गहराई से")
    फल गहरा(न - 1)

कोशिश:
    गहरा(3)
पकड़ो जाल_त्रुटि ई:
    बताओ "कार्य से: " + ई.संदेश

बताओ "== 8. लूप में फेंको =="
कुल है 0
कोशिश:
    i के लिए 10 में:
        कुल है कुल + i
        यदि i बराबर 3:
            फेंको गणना_त्रुटि("लूप रोका")
पकड़ो गणना_त्रुटि ई:
    बताओ ई.संदेश + ", कुल=" + कुल

बताओ "== 9. अमान्य फेंको मान =="
कोशिश:
    फेंको 42
पकड़ो त्रुटि:
    बताओ "पकड़ा: " + त्रुटि

वर्ग सादा:
    विधि बनाओ():
        यह.x है 1

कोशिश:
    फेंको सादा()
पकड़ो त्रुटि:
    बताओ "पकड़ा: " + त्रुटि

बताओ "== सम्पूर्ण =="
