# Phase 17 — सजावट (decorators) test

# ── 1. Basic decorator: wrap a function ──────────────────────
विधि दुगुना_करो(f):
    फल लाम्डा(x): f(x) * 2

@दुगुना_करो
विधि बढ़ाओ(x):
    फल x + 1

जाँचो बढ़ाओ(5) बराबर 12, "1: दुगुना_करो(बढ़ाओ)(5) = (5+1)*2"
बताओ "1 ठीक: " + बढ़ाओ(5)

# ── 2. Stacked decorators — applied bottom-up ─────────────────
विधि जोड़_दस(f):
    फल लाम्डा(x): f(x) + 10

@जोड़_दस
@दुगुना_करो
विधि पहचान(x):
    फल x

# जोड़_दस(दुगुना_करो(पहचान))(3) = (3*2)+10 = 16
जाँचो पहचान(3) बराबर 16, "2: stacked order"
बताओ "2 ठीक: " + पहचान(3)

# ── 3. Decorator factory — @कारखाना(आर्ग) ────────────────────
विधि गुणा_से(n):
    फल लाम्डा(f): लाम्डा(x): f(x) * n

@गुणा_से(5)
विधि तिगुना_आधार(x):
    फल x + 2

जाँचो तिगुना_आधार(4) बराबर 30, "3: factory (4+2)*5"
बताओ "3 ठीक: " + तिगुना_आधार(4)

# ── 4. Decorated function is a first-class value ─────────────
प्रति है बढ़ाओ
जाँचो प्रति(10) बराबर 22, "4: assigned to variable"
बताओ "4 ठीक: " + प्रति(10)

# ── 5. Decorated function in HOF ──────────────────────────────
जाँचो मानचित्र([1, 2, 3], बढ़ाओ).मिलाओ(",") बराबर "4,6,8", "5: मानचित्र"
बताओ "5 ठीक: " + मानचित्र([1, 2, 3], बढ़ाओ).मिलाओ(",")

# ── 6. Two-arg function through a logging decorator ───────────
विधि लॉग_करो(f):
    फल लाम्डा(अ, ब): f(अ, ब)

@लॉग_करो
विधि जोड़ो(अ, ब):
    फल अ + ब

जाँचो जोड़ो(7, 8) बराबर 15, "6: two args"
बताओ "6 ठीक: " + जोड़ो(7, 8)

# ── 7. Decorator defined inside a function (local scope) ─────
विधि बनाने_वाला():
    @दुगुना_करो
    विधि भीतरी(x):
        फल x + 100
    फल भीतरी(1)

जाँचो बनाने_वाला() बराबर 202, "7: nested decorated function"
बताओ "7 ठीक: " + बनाने_वाला()

बताओ "सजावट: सभी परीक्षण सफल!"
