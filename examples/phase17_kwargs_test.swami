। Phase 17 — कीवर्ड तर्क (keyword arguments) परीक्षण ।

बताओ "== 1. साधारण कीवर्ड तर्क =="
विधि घटाओ(अ, ब):
    फल अ - ब

बताओ घटाओ(10, 3)
बताओ घटाओ(अ=10, ब=3)
बताओ घटाओ(ब=3, अ=10)
बताओ घटाओ(10, ब=3)

बताओ "== 2. डिफ़ॉल्ट + कीवर्ड =="
विधि अभिवादन(नाम, शैली="नमस्ते", चिह्न="!"):
    फल शैली + " " + नाम + चिह्न

बताओ अभिवादन("राम")
बताओ अभिवादन("राम", चिह्न="?")
बताओ अभिवादन(नाम="सीता", शैली="प्रणाम")

बताओ "== 3. वर्ग निर्माता =="
वर्ग व्यक्ति:
    विधि बनाओ(नाम, आयु=18):
        यह.नाम है नाम
        यह.आयु है आयु

प है व्यक्ति(आयु=30, नाम="मोहन")
बताओ प.नाम
बताओ प.आयु
प2 है व्यक्ति(नाम="गीता")
बताओ प2.आयु

बताओ "== 4. विरासत निर्माता =="
वर्ग छात्र(व्यक्ति):
    विधि परिचय():
        फल यह.नाम + " (" + यह.आयु + ")"

स है छात्र(नाम="अर्जुन", आयु=12)
बताओ स.परिचय()

बताओ "== 5. लाम्डा / प्रथम-श्रेणी विधि =="
f है लाम्डा(x, y): x * 10 + y
बताओ f(y=2, x=1)
g है घटाओ
बताओ g(ब=1, अ=100)

बताओ "== 6. त्रुटियाँ पकड़ो =="
कोशिश:
    बताओ घटाओ(अ=1, गलत=2)
पकड़ो त्रुटि:
    बताओ "पकड़ा 1: " + त्रुटि

कोशिश:
    बताओ घटाओ(10, अ=1)
पकड़ो त्रुटि:
    बताओ "पकड़ा 2: " + त्रुटि

कोशिश:
    बताओ घटाओ(अ=5)
पकड़ो त्रुटि:
    बताओ "पकड़ा 3: " + त्रुटि

बताओ "== समाप्त =="
