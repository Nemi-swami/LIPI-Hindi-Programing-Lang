# Phase 6 — वर्ग (Classes) test

वर्ग व्यक्ति:
    विधि बनाओ(नाम, आयु):
        यह.नाम है नाम
        यह.आयु है आयु
    विधि परिचय():
        बताओ यह.नाम + " की आयु " + यह.आयु + " वर्ष है"
    विधि बड़ा_है(सीमा):
        यदि यह.आयु से अधिक सीमा:
            बताओ यह.नाम + " बड़ा है"
        अन्यथा:
            बताओ यह.नाम + " छोटा है"

# create instances
प1 है व्यक्ति("राम", 30)
प2 है व्यक्ति("सीता", 25)

# call methods
प1.परिचय()
प2.परिचय()

# call method with arg
प1.बड़ा_है(20)
प2.बड़ा_है(28)

# access fields directly
बताओ "नाम: " + प1.नाम
बताओ "आयु: " + प2.आयु

# print instance (shows all fields)
बताओ प1
