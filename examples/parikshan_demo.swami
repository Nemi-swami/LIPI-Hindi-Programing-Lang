# परीक्षण framework demo — run with:  lipi test examples/parikshan_demo.swami
# Normal `lipi examples/parikshan_demo.swami` skips the test blocks entirely.

विधि जोड़ो(अ, ब):
    फल अ + ब

विधि भाग(अ, ब):
    यदि ब बराबर 0:
        फेंको "शून्य से भाग"
    फल अ / ब

गिनती है 0

परीक्षण "जोड़ सही है":
    जाँचो जोड़ो(2, 3) बराबर 5
    जाँचो जोड़ो(-1, 1) बराबर 0

परीक्षण "भाग सही है":
    जाँचो भाग(10, 2) बराबर 5

परीक्षण "शून्य भाग फेंकता है":
    पकड़ा है असत्य
    कोशिश:
        भाग(1, 0)
    पकड़ो त्रुटि:
        पकड़ा है सत्य
    जाँचो पकड़ा, "त्रुटि अपेक्षित थी"

परीक्षण "परीक्षण अलग-थलग हैं":
    # हर परीक्षण ताज़ा VM में चलता है — setup फिर से चलता है
    जाँचो गिनती बराबर 0
    गिनती है 99

परीक्षण "जानबूझकर विफल (demo)":
    जाँचो जोड़ो(2, 2) बराबर 5, "2+2 कभी 5 नहीं"

बताओ "सामान्य रन: परीक्षण ब्लॉक छोड़े गए"
