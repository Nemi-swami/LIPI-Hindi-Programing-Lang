# Phase 17 — static methods + abstract classes

वर्ग गणित_उपकरण:
    साझा विधि वर्ग_करो(न):
        फल न * न
    साझा विधि जोड़ो(अ, ब):
        फल अ + ब
    विधि बनाओ(मान):
        यह.मान है मान
    विधि दुगुना():
        फल यह.मान * 2

बताओ "== 1. static method =="
जाँचो गणित_उपकरण.वर्ग_करो(5) बराबर 25, "static वर्ग गलत"
जाँचो गणित_उपकरण.जोड़ो(3, 4) बराबर 7, "static जोड़ो गलत"

बताओ "== 2. instance still works =="
ग है गणित_उपकरण(10)
जाँचो ग.दुगुना() बराबर 20, "instance method गलत"
जाँचो ग.मान बराबर 10, "instance field गलत"

बताओ "== 3. static with default param =="
वर्ग नमस्कार:
    साझा विधि बनाओ_संदेश(नाम="दुनिया"):
        फल "नमस्ते " + नाम
जाँचो नमस्कार.बनाओ_संदेश() बराबर "नमस्ते दुनिया", "static default गलत"
जाँचो नमस्कार.बनाओ_संदेश("राम") बराबर "नमस्ते राम", "static arg गलत"

बताओ "== 4. abstract class cannot instantiate =="
सार वर्ग आकृति:
    विधि क्षेत्रफल():
        फल 0

कोशिश:
    आ है आकृति()
    बताओ "नहीं आना चाहिए"
पकड़ो त्रुटि:
    बताओ "पकड़ा: सार वर्ग"

बताओ "== 5. concrete subclass of abstract works =="
वर्ग वर्ग_आकृति(आकृति):
    विधि बनाओ(भुजा):
        यह.भुजा है भुजा
    विधि क्षेत्रफल():
        फल यह.भुजा * यह.भुजा

व है वर्ग_आकृति(4)
जाँचो व.क्षेत्रफल() बराबर 16, "subclass गलत"

बताओ "== सम्पूर्ण =="
