# Phase 17 — OrderedDict (क्रमित_कोश) — insertion-ordered map

बताओ "== 1. insertion order preserved =="
od है क्रमित_कोश()
od है क्रमित_रखो(od, "ग", 3)
od है क्रमित_रखो(od, "अ", 1)
od है क्रमित_रखो(od, "ब", 2)

बताओ क्रमित_कुंजियाँ(od)       # ["ग", "अ", "ब"]  — NOT sorted
जाँचो क्रमित_कुंजियाँ(od) बराबर ["ग", "अ", "ब"], "order गलत"
जाँचो क्रमित_मान(od) बराबर [3, 1, 2], "values गलत"

बताओ "== 2. get =="
बताओ क्रमित_पाओ(od, "अ")       # 1
जाँचो क्रमित_पाओ(od, "अ") बराबर 1, "get गलत"
जाँचो क्रमित_पाओ(od, "नहीं") बराबर शून्य, "missing गलत"

बताओ "== 3. update in place keeps position =="
od है क्रमित_रखो(od, "अ", 99)
जाँचो क्रमित_कुंजियाँ(od) बराबर ["ग", "अ", "ब"], "update-order गलत"
जाँचो क्रमित_पाओ(od, "अ") बराबर 99, "update-value गलत"

बताओ "== 4. numeric keys =="
न है क्रमित_कोश()
न है क्रमित_रखो(न, 10, "दस")
न है क्रमित_रखो(न, 5, "पाँच")
जाँचो क्रमित_पाओ(न, 10) बराबर "दस", "numkey गलत"
बताओ क्रमित_कुंजियाँ(न)        # [10, 5]

बताओ ""
बताओ "सब परीक्षण पास ✓"
