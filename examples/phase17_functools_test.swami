# Phase 17 — Functools (स्मरण / आंशिक / संयोजित)

बताओ "== 1. आंशिक (partial application) =="
विधि जोड़ो(अ, ब, स):
    फल अ + ब + स

जोड़_दस है आंशिक(जोड़ो, 10)
बताओ जोड़_दस(5, 3)             # 18
जाँचो जोड़_दस(5, 3) बराबर 18, "partial गलत"

जोड़_पंद्रह है आंशिक(जोड़ो, 10, 5)
बताओ जोड़_पंद्रह(100)          # 115
जाँचो जोड़_पंद्रह(100) बराबर 115, "partial2 गलत"

बताओ "== 2. संयोजित (compose) =="
विधि दुगुना(x):
    फल x * 2
विधि बढ़ाओ(x):
    फल x + 1

# संयोजित(दुगुना, बढ़ाओ)(x) = दुगुना(बढ़ाओ(x))
दुगुना_फिर_बढ़ा है संयोजित(दुगुना, बढ़ाओ)
बताओ दुगुना_फिर_बढ़ा(5)       # दुगुना(6) = 12
जाँचो दुगुना_फिर_बढ़ा(5) बराबर 12, "compose गलत"

बताओ "== 3. स्मरण (memoize) — persistent cache =="
वैश्विक_गिनती है 0

विधि महंगा(n):
    वैश्विक वैश्विक_गिनती
    वैश्विक_गिनती है वैश्विक_गिनती + 1
    फल n * n

तेज है स्मरण(महंगा)
बताओ तेज(5)                    # 25  (compute)
बताओ तेज(5)                    # 25  (cached)
बताओ तेज(5)                    # 25  (cached)
बताओ तेज(6)                    # 36  (compute)
बताओ वैश्विक_गिनती            # 2 — महंगा ran only twice
जाँचो वैश्विक_गिनती बराबर 2, "memoize cache गलत"

बताओ "== 4. memoized fibonacci =="
विधि फिब(n):
    यदि n से कम 2:
        फल n
    फल फिब(n - 1) + फिब(n - 2)

स्मृत_फिब है स्मरण(फिब)
बताओ स्मृत_फिब(15)            # 610
जाँचो स्मृत_फिब(15) बराबर 610, "memo fib गलत"

बताओ "== 5. functools with HOFs =="
बढ़ाओ_सब है मानचित्र([1, 2, 3], आंशिक(जोड़ो, 0, 0))
बताओ बढ़ाओ_सब                # [1, 2, 3]
जाँचो बढ़ाओ_सब बराबर [1, 2, 3], "functools+HOF गलत"

बताओ ""
बताओ "सब परीक्षण पास ✓"
