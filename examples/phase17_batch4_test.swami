# Phase 17 — walrus, product, combinations

बताओ "== 1. walrus in condition =="
विधि लंबाई_जाँच(श):
    यदि (न := श.लम्बाई()) से अधिक 3:
        फल "लंबा: " + न
    फल "छोटा: " + न
जाँचो लंबाई_जाँच("नमस्ते") बराबर "लंबा: 6", "walrus लंबा गलत"
जाँचो लंबाई_जाँच("कम") बराबर "छोटा: 2", "walrus छोटा गलत"

बताओ "== 2. walrus reuse =="
य है [1, 2, 3, 4, 5]
यदि (कुल := योग_सब(य)) से अधिक 10:
    बताओ "योग बड़ा है: " + कुल
जाँचो कुल बराबर 15, "walrus reuse गलत"

विधि योग_सब(सूची):
    क है 0
    i के लिए सूची में:
        क है क + i
    फल क

बताओ "== 3. cartesian product (कार्तीय) =="
प है कार्तीय([1, 2], ["अ", "ब"])
जाँचो प.लम्बाई() बराबर 4, "product लम्बाई गलत"
जाँचो प[0] बराबर [1, "अ"], "product[0] गलत"
जाँचो प[3] बराबर [2, "ब"], "product[3] गलत"

बताओ "== 4. combinations (सर्व_संयोजन) =="
स है सर्व_संयोजन([1, 2, 3, 4], 2)
जाँचो स.लम्बाई() बराबर 6, "combinations count गलत"
जाँचो स[0] बराबर [1, 2], "combinations[0] गलत"
जाँचो स[5] बराबर [3, 4], "combinations[5] गलत"

बताओ "== 5. combinations r=3 =="
स3 है सर्व_संयोजन([1, 2, 3], 3)
जाँचो स3.लम्बाई() बराबर 1, "combinations r=3 count गलत"
जाँचो स3[0] बराबर [1, 2, 3], "combinations r=3 मान गलत"

बताओ "== सम्पूर्ण =="
