# Phase 17 — operator overloading on classes

वर्ग सदिश:
    विधि बनाओ(x, y):
        यह.x है x
        यह.y है y
    विधि __जोड़ो__(दूसरा):
        फल सदिश(यह.x + दूसरा.x, यह.y + दूसरा.y)
    विधि __घटाओ__(दूसरा):
        फल सदिश(यह.x - दूसरा.x, यह.y - दूसरा.y)
    विधि __गुणा__(क):
        फल सदिश(यह.x * क, यह.y * क)

बताओ "== 1. vector add =="
अ है सदिश(1, 2)
ब है सदिश(3, 4)
स है अ + ब
जाँचो स.x बराबर 4, "add x गलत"
जाँचो स.y बराबर 6, "add y गलत"

बताओ "== 2. vector sub =="
द है ब - अ
जाँचो द.x बराबर 2, "sub x गलत"
जाँचो द.y बराबर 2, "sub y गलत"

बताओ "== 3. scalar mul =="
म है अ * 5
जाँचो म.x बराबर 5, "mul x गलत"
जाँचो म.y बराबर 10, "mul y गलत"

बताओ "== 4. chained =="
च है (अ + ब) * 2
जाँचो च.x बराबर 8, "chain x गलत"
जाँचो च.y बराबर 12, "chain y गलत"

बताओ "== 5. money mod =="
वर्ग पैसा:
    विधि बनाओ(राशि):
        यह.राशि है राशि
    विधि __शेष__(भाजक):
        फल यह.राशि % भाजक

प है पैसा(17)
जाँचो (प % 5) बराबर 2, "mod गलत"

बताओ "== सम्पूर्ण =="
