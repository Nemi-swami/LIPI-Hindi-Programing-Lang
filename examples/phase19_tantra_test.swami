# Phase 19 F2 — भारत.तंत्र (raw memory + MMIO)
# Proves LIPI can allocate raw buffers, marshal C data, and do volatile
# register-style access — the primitives for hardware/driver communication.
आयात भारत.तंत्र

बताओ "== 1. allocate a 64-byte buffer =="
बफ़र है स्मृति_आवंटन(64)
जाँचो बफ़र से अधिक 0, "आवंटन विफल"
जाँचो स्मृति_आकार(बफ़र) बराबर 64, "आकार गलत"
बताओ "सूचक = " + बफ़र + ", आकार = " + स्मृति_आकार(बफ़र)

बताओ "== 2. byte round-trip =="
स्मृति_लिखो_बाइट(बफ़र, 0, 255)
स्मृति_लिखो_बाइट(बफ़र, 1, 42)
जाँचो स्मृति_पढ़ो_बाइट(बफ़र, 0) बराबर 255, "बाइट 0 गलत"
जाँचो स्मृति_पढ़ो_बाइट(बफ़र, 1) बराबर 42, "बाइट 1 गलत"

बताओ "== 3. 64-bit int round-trip =="
स्मृति_लिखो_पूर्ण(बफ़र, 8, 1234567890)
जाँचो स्मृति_पढ़ो_पूर्ण(बफ़र, 8) बराबर 1234567890, "पूर्ण गलत"

बताओ "== 4. double round-trip =="
स्मृति_लिखो_दशमलव(बफ़र, 16, 3.14159)
जाँचो निरपेक्ष(स्मृति_पढ़ो_दशमलव(बफ़र, 16) - 3.14159) से कम 0.00001, "दशमलव गलत"

बताओ "== 5. C-string round-trip (for FFI) =="
स्मृति_लिखो_वाक्य(बफ़र, 24, "नमस्ते")
जाँचो स्मृति_वाक्य(बफ़र + 24) बराबर "नमस्ते", "वाक्य गलत"

बताओ "== 6. volatile MMIO on a known-valid address =="
# कच्चा_* poke/peek — here we point at our own buffer so the test is safe.
# On real hardware, पता = a memory-mapped device register.
कच्चा_लिखो३२(बफ़र, 3735928559)          # 0xDEADBEEF as decimal
जाँचो कच्चा_पढ़ो३२(बफ़र) बराबर 3735928559, "MMIO 32-bit गलत"
कच्चा_लिखो(बफ़र + 4, 7)
जाँचो कच्चा_पढ़ो(बफ़र + 4) बराबर 7, "MMIO 8-bit गलत"

बताओ "== 7. bounds check catches overflow =="
पकड़ा है असत्य
कोशिश:
    स्मृति_लिखो_पूर्ण(बफ़र, 60, 1)        # 60+8 > 64
पकड़ो त्रुटि:
    पकड़ा है सत्य
जाँचो पकड़ा, "सीमा जाँच विफल"

बताओ "== 8. free =="
जाँचो स्मृति_मुक्त(बफ़र), "मुक्त विफल"

बताओ ""
बताओ "सब परीक्षण पास ✓"
