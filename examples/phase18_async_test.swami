# Phase 18 — Async / await (प्रतीक्षा + चलाओ + इकट्ठा + सोओ)

बताओ "== 1. simple async + await =="
विधि काम(n):
    प्रतीक्षा सोओ(10)
    फल n * 2

जाँचो चलाओ(काम(21)) बराबर 42, "async result गलत"
बताओ चलाओ(काम(21))            # 42

बताओ "== 2. await another async task =="
विधि बाहरी(n):
    म है प्रतीक्षा काम(n)
    फल म + 1

जाँचो चलाओ(बाहरी(10)) बराबर 21, "nested await गलत"
बताओ चलाओ(बाहरी(10))          # 21

बताओ "== 3. concurrent इकट्ठा (gather) =="
विधि धीमा(आईडी, देरी):
    प्रतीक्षा सोओ(देरी)
    फल आईडी

परिणाम है इकट्ठा(धीमा(1, 50), धीमा(2, 50), धीमा(3, 50))
बताओ परिणाम                    # [1, 2, 3]
जाँचो परिणाम बराबर [1, 2, 3], "gather गलत"

बताओ ""
बताओ "सब परीक्षण पास ✓"
