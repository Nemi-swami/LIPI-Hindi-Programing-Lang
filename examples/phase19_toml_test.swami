# Phase 19 F6 — भारत.टोमल (TOML config parser)
आयात भारत.टोमल

पाठ है """# lipi project config
नाम = "my-app"
संस्करण = 3
सक्रिय = true
टैग = ["वेब", "एपीआई", "तेज"]

[सर्वर]
पोर्ट = 8080
होस्ट = "127.0.0.1"

[डेटाबेस.मुख्य]
url = "localhost"
पूल = 10"""

कोश है toml_पढ़ो(पाठ)
जाँचो कोश["नाम"] बराबर "my-app", "नाम गलत"
जाँचो कोश["संस्करण"] बराबर 3, "संस्करण गलत"
जाँचो कोश["सक्रिय"] बराबर सत्य, "बूल गलत"
जाँचो कोश["टैग"][1] बराबर "एपीआई", "सरणी गलत"
जाँचो कोश["सर्वर"]["पोर्ट"] बराबर 8080, "नेस्टेड टेबल गलत"
जाँचो कोश["डेटाबेस"]["मुख्य"]["पूल"] बराबर 10, "गहरी नेस्टिंग गलत"

बताओ "नाम = " + कोश["नाम"]
बताओ "पोर्ट = " + कोश["सर्वर"]["पोर्ट"]
बताओ ""
बताओ "सब परीक्षण पास ✓"
