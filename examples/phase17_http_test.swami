। Phase 17B — भारत.http परीक्षण (सर्वर: examples/http_test_server.js, 127.0.0.1:8731) ।
आयात भारत.http
आयात भारत.json

बताओ "== 1: GET /namaste =="
उ है http_पाओ("http://127.0.0.1:8731/namaste")
बताओ "स्थिति: " + उ["स्थिति"]
बताओ "सामग्री: " + उ["सामग्री"]
शीर्ष है उ["शीर्षक"]
बताओ "x-lipi: " + शीर्ष["x-lipi"]

बताओ "== 2: POST /echo =="
डेटा है {"नाम": "लिपि", "अंक": 17}
भेजना है json_लिखो(डेटा)
ज है http_भेजो("http://127.0.0.1:8731/echo", भेजना)
बताओ "स्थिति: " + ज["स्थिति"]
बताओ "content-type: " + ज["शीर्षक"]["content-type"]
यदि ज["सामग्री"] बराबर भेजना:
    बताओ "echo सही: " + ज["सामग्री"]
अन्यथा:
    बताओ "echo गलत: " + ज["सामग्री"]

बताओ "== 3: GET /chunked =="
च है http_पाओ("http://127.0.0.1:8731/chunked")
बताओ "स्थिति: " + च["स्थिति"]
बताओ "सामग्री: " + च["सामग्री"]
बताओ "transfer-encoding: " + च["शीर्षक"]["transfer-encoding"]

बताओ "== 4: GET /missing (404 — त्रुटि नहीं) =="
म है http_पाओ("http://127.0.0.1:8731/missing")
बताओ "स्थिति: " + म["स्थिति"]
बताओ "सामग्री: " + म["सामग्री"]

बताओ "== 5: https अस्वीकृत =="
कोशिश:
    क है http_पाओ("https://example.com/")
    बताओ "विफल: त्रुटि नहीं पकड़ी!"
पकड़ो त्रुटि:
    बताओ "पकड़ी: " + त्रुटि

बताओ "== 6: अमान्य URL =="
कोशिश:
    ख है http_पाओ("ftp://example.com/")
    बताओ "विफल: त्रुटि नहीं पकड़ी!"
पकड़ो त्रुटि:
    बताओ "पकड़ी: " + त्रुटि
कोशिश:
    ग है http_पाओ("bina-scheme-wala")
    बताओ "विफल: त्रुटि नहीं पकड़ी!"
पकड़ो त्रुटि:
    बताओ "पकड़ी: " + त्रुटि

बताओ "== 7: कनेक्शन अस्वीकृत (127.0.0.1:1) =="
कोशिश:
    घ है http_पाओ("http://127.0.0.1:1/")
    बताओ "विफल: त्रुटि नहीं पकड़ी!"
पकड़ो त्रुटि:
    बताओ "कनेक्शन त्रुटि पकड़ी गई"

बताओ "== 8: custom headers GET =="
ह है http_पाओ("http://127.0.0.1:8731/namaste", {"X-Custom": "lipi-test", "Accept": "text/plain"})
बताओ "स्थिति: " + ह["स्थिति"]

बताओ "सम्पूर्ण — सभी http परीक्षण पारित"
