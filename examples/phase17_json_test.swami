# Phase 17 — भारत.json परीक्षण
आयात भारत.json

बताओ "== 1. नेस्टेड ऑब्जेक्ट पार्स =="
पाठ है """{"नाम": "राम", "आयु": 30, "छात्र": false, "पता": null, "अंक": [85, 92.5, -3, 1e2], "परिवार": {"पिता": "दशरथ", "भाई": ["लक्ष्मण", "भरत"]}}"""
व है json_पढ़ो(पाठ)
बताओ व["नाम"]
बताओ व["आयु"]
बताओ व["छात्र"]
बताओ व["पता"]
बताओ व["अंक"]
बताओ व["अंक"][3]
बताओ व["परिवार"]["पिता"]
बताओ व["परिवार"]["भाई"][1]

बताओ "== 2. json_लिखो =="
कोश है {"शहर": "अयोध्या", "जनसंख्या": 55890, "नदी": "सरयू"}
कोश["सूची"] है [1, 2.5, सत्य, असत्य]
बताओ json_लिखो(कोश)
बताओ json_लिखो([10, "क", असत्य])
बताओ json_लिखो("सीधा वाक्य")
बताओ json_लिखो(42)
बताओ json_लिखो(3.14)

बताओ "== 3. round trip =="
मूल है {"क": [1, 2, {"ख": "मान"}], "ग": सत्य}
पंक्ति है json_लिखो(मूल)
बताओ पंक्ति
वापस है json_पढ़ो(पंक्ति)
बताओ वापस["क"][2]["ख"]
बताओ json_लिखो(वापस)
जाँचो पंक्ति बराबर json_लिखो(वापस), "round trip विफल"
बताओ "round trip सफल"

बताओ "== 4. escape परीक्षण =="
ई है json_पढ़ो("\"पंक्ति1\\nपंक्ति2\\t\\\"उद्धरण\\\" \\\\ \\/ \\u0915 \\ud83d\\ude00\"")
बताओ ई
बताओ json_लिखो(ई)

बताओ "== 5. अमान्य JSON =="
कोशिश:
    खराब है json_पढ़ो("{\"क\": }")
    बताओ "यहाँ नहीं आना चाहिए"
पकड़ो त्रुटि:
    बताओ "पकड़ा: " + त्रुटि

कोशिश:
    खराब2 है json_पढ़ो("[1, 2,")
    बताओ "यहाँ नहीं आना चाहिए"
पकड़ो त्रुटि:
    बताओ "पकड़ा: " + त्रुटि

बताओ "== सम्पूर्ण =="
