# Phase 17 — SQL / local DB (भारत.संग्रह)
आयात भारत.संग्रह

db है db_नया()

बताओ "== 1. CREATE + INSERT =="
db_चलाओ(db, "CREATE TABLE छात्र (id, नाम, अंक)")
db_चलाओ(db, "INSERT INTO छात्र VALUES (1, 'राम', 85)")
db_चलाओ(db, "INSERT INTO छात्र VALUES (2, 'सीता', 92)")
db_चलाओ(db, "INSERT INTO छात्र VALUES (3, 'मोहन', 78)")
n है db_चलाओ(db, "INSERT INTO छात्र (id, नाम, अंक) VALUES (4, 'गीता', 95)")
जाँचो n बराबर 1, "insert गिनती गलत"

बताओ "== 2. SELECT * =="
सब है db_चलाओ(db, "SELECT * FROM छात्र")
जाँचो सब.लम्बाई() बराबर 4, "row गिनती गलत"
बताओ सब[0]["नाम"]               # राम

बताओ "== 3. WHERE =="
उच्च है db_चलाओ(db, "SELECT नाम, अंक FROM छात्र WHERE अंक > 90")
बताओ उच्च
जाँचो उच्च.लम्बाई() बराबर 2, "WHERE गिनती गलत"

बताओ "== 4. WHERE with AND/OR =="
र है db_चलाओ(db, "SELECT नाम FROM छात्र WHERE अंक > 80 AND अंक < 95")
जाँचो र.लम्बाई() बराबर 2, "AND गिनती गलत"

बताओ "== 5. ORDER BY DESC + LIMIT =="
शीर्ष है db_चलाओ(db, "SELECT नाम, अंक FROM छात्र ORDER BY अंक DESC LIMIT 2")
बताओ शीर्ष[0]["नाम"]            # गीता (95)
जाँचो शीर्ष[0]["नाम"] बराबर "गीता", "ORDER BY गलत"
जाँचो शीर्ष.लम्बाई() बराबर 2, "LIMIT गलत"

बताओ "== 6. UPDATE =="
u है db_चलाओ(db, "UPDATE छात्र SET अंक = 100 WHERE नाम = 'मोहन'")
जाँचो u बराबर 1, "UPDATE गिनती गलत"
म है db_चलाओ(db, "SELECT अंक FROM छात्र WHERE नाम = 'मोहन'")
जाँचो म[0]["अंक"] बराबर 100, "UPDATE मान गलत"

बताओ "== 7. DELETE =="
d है db_चलाओ(db, "DELETE FROM छात्र WHERE अंक < 90")
बताओ d                          # कितने हटाए
शेष है db_चलाओ(db, "SELECT * FROM छात्र")
जाँचो शेष.लम्बाई() बराबर 3, "DELETE के बाद गिनती गलत"

बताओ "== 8. save + load roundtrip =="
तर्क_सूची है तर्क()
यदि तर्क_सूची.लम्बाई() से अधिक 0:
    पथ है पथ_जोड़ो(तर्क_सूची[0], "test.lipidb")
    db_सहेजो(db, पथ)
    db2 है db_खोलो(पथ)
    फिर है db_चलाओ(db2, "SELECT * FROM छात्र ORDER BY id")
    जाँचो फिर.लम्बाई() बराबर 3, "load के बाद गिनती गलत"
    बताओ "save/load सत्यापित ✓"
    फाइल_हटाओ(पथ)

बताओ ""
बताओ "सब परीक्षण पास ✓"
