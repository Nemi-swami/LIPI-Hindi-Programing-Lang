# Phase 17 — भारत.समय (DateTime) परीक्षण — सभी मान निर्धारक (deterministic)
आयात भारत.समय

बताओ "== 1. समय_बनाओ — ज्ञात युग =="
बताओ समय_बनाओ(1970, 1, 1, 5, 30, 0)
बताओ समय_बनाओ(2000, 1, 1)
त है समय_बनाओ(2026, 6, 12, 14, 30, 5)

बताओ "== 2. समय_विवरण =="
व है समय_विवरण(त)
बताओ व["वर्ष"]
बताओ व["माह"]
बताओ व["दिन"]
बताओ व["घंटा"]
बताओ व["मिनट"]
बताओ व["सेकंड"]
बताओ व["वार_नाम"]
बताओ व["माह_नाम"]

बताओ "== 3. समय_स्वरूप =="
बताओ समय_स्वरूप(त)
बताओ समय_स्वरूप(0)

बताओ "== 4. दिनांक_पार्स =="
यदि दिनांक_पार्स("2026-06-12 14:30:05") बराबर त:
    बताओ "समय पार्स सही"
यदि दिनांक_पार्स("2026-06-12") बराबर समय_बनाओ(2026, 6, 12):
    बताओ "तिथि पार्स सही"

बताओ "== 5. दिन_अंतर + समय_जोड़ो =="
बताओ दिन_अंतर(समय_बनाओ(2026, 1, 1), समय_बनाओ(2026, 6, 12))
कल है समय_जोड़ो(त, 1)
बताओ समय_स्वरूप(कल)
बताओ दिन_अंतर(त, कल)
बताओ समय_स्वरूप(समय_जोड़ो(त, 0, 10, 0, 0))

बताओ "== 6. अधिवर्ष + माह_दिन =="
बताओ अधिवर्ष(2000)
बताओ अधिवर्ष(1900)
बताओ अधिवर्ष(2024)
बताओ अधिवर्ष(2026)
बताओ माह_दिन(2024, 2)
बताओ माह_दिन(2026, 2)

बताओ "== 7. 1970 से पहले — स्वतंत्रता दिवस =="
स है समय_विवरण(समय_बनाओ(1947, 8, 15))
बताओ स["वार_नाम"]
बताओ समय_स्वरूप(समय_बनाओ(1947, 8, 15))

बताओ "== 8. त्रुटियाँ (पकड़ने योग्य) =="
कोशिश:
    समय_बनाओ(2026, 13, 1)
पकड़ो त्रुटि:
    बताओ "पकड़ा: " + त्रुटि
कोशिश:
    समय_बनाओ(2026, 2, 29)
पकड़ो त्रुटि:
    बताओ "पकड़ा: " + त्रुटि
कोशिश:
    दिनांक_पार्स("12/06/2026")
पकड़ो त्रुटि:
    बताओ "पकड़ा: " + त्रुटि

बताओ "== 9. समय_अभी (केवल जाँच — मान बदलता रहता है) =="
यदि समय_अभी() से अधिक 1700000000:
    बताओ "समय_अभी ठीक"

बताओ "== सम्पूर्ण =="
