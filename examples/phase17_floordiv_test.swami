। Phase 17 — // पूर्णांक भाग (floor division) परीक्षण ।

बताओ "== 1. साधारण =="
बताओ 7 // 2
बताओ 10 // 3
बताओ 100 // 10
बताओ 1 // 3

बताओ "== 2. ऋणात्मक (Python जैसा floor) =="
बताओ -7 // 2
बताओ 7 // -2
बताओ -7 // -2

बताओ "== 3. दशमलव =="
बताओ 7.5 // 2
बताओ 9.9 // 3.3

बताओ "== 4. प्राथमिकता — * / // % एक स्तर =="
बताओ 1 + 7 // 2
बताओ 20 // 3 * 2
बताओ 100 // 10 // 2

बताओ "== 5. चर और विधि में =="
क है 17
ख है 5
बताओ क // ख
विधि आधा(न):
    फल न // 2
बताओ आधा(99)

बताओ "== 6. शून्य से भाग =="
कोशिश:
    बताओ 5 // 0
पकड़ो त्रुटि:
    बताओ "पकड़ा: " + त्रुटि

बताओ "== समाप्त =="
