# Phase 19 F1 — भारत.बाह्य (Foreign Function Interface)
# Calls the Windows C runtime (msvcrt.dll) — proves LIPI can reach any C library.
आयात भारत.बाह्य

बताओ "== 1. load msvcrt =="
पुस्तकालय है बाह्य_पुस्तकालय("msvcrt.dll")
जाँचो पुस्तकालय से अधिक 0, "msvcrt लोड नहीं हुआ"
बताओ "लोड हुआ, हैंडल = " + पुस्तकालय

बताओ "== 2. int f(int): abs(-42) =="
प है बाह्य_बुलाओ(पुस्तकालय, "abs", "i:i", -42)
जाँचो प बराबर 42, "abs(-42) != 42"
बताओ "abs(-42) = " + प

बताओ "== 3. int f(int,int)-ish: toupper('a') =="
# tolower/toupper take + return int; 'a' = 97, 'A' = 65
बड़ा है बाह्य_बुलाओ(पुस्तकालय, "toupper", "i:i", 97)
जाँचो बड़ा बराबर 65, "toupper('a') != 'A'"
बताओ "toupper(97) = " + बड़ा

बताओ "== 4. double f(double): sqrt(2.0) =="
मूल है बाह्य_बुलाओ(पुस्तकालय, "sqrt", "d:d", 2)
जाँचो निरपेक्ष(मूल - 1.4142135) से कम 0.001, "sqrt(2) गलत"
बताओ "sqrt(2) = " + मूल

बताओ "== 5. double f(double,double): pow(2,10) =="
घ है बाह्य_बुलाओ(पुस्तकालय, "pow", "dd:d", 2, 10)
जाँचो घ बराबर 1024, "pow(2,10) != 1024"
बताओ "pow(2,10) = " + घ

बताओ "== 6. mixed-mode error is caught =="
पकड़ा है असत्य
कोशिश:
    गलत है बाह्य_बुलाओ(पुस्तकालय, "pow", "id:d", 2, 3)
पकड़ो त्रुटि:
    पकड़ा है सत्य
जाँचो पकड़ा, "मिश्रित मोड त्रुटि पकड़ी नहीं गई"

बताओ "== 7. unload =="
बंद है बाह्य_बंद(पुस्तकालय)
जाँचो बंद, "बाह्य_बंद विफल"

बताओ ""
बताओ "सब परीक्षण पास ✓"
