# deep nesting
विधि गहरी_विधि(न4):
    यदि न4 बराबर 0:
        फल "आधार"
    फल "[" + गहरी_विधि(न4 - 1) + "]"

जाँचो("गहरी पुनरावृत्ति 5", गहरी_विधि(5), "[[[[[आधार]]]]]")

