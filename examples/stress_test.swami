# 26. जटिल कार्यक्रम — COMPLEX PROGRAMS
# ══════════════════════════════════════════════════════════════════════
शीर्षक("26. जटिल कार्यक्रम")

# Sieve of Eratosthenes
विधि अभाज्य_छलनी(सीमा):
    छलनी है []
    i के लिए सीमा + 1 में:
        छलनी है छलनी.जोड़ो(सत्य)
    छलनी[0] है असत्य
    छलनी[1] है असत्य
    i के लिए सीमा + 1 में:
        यदि i >= 2 और छलनी[i]:
            j है i * 2
            जब तक j <= सीमा:
                छलनी[j] है असत्य
                j है j + i
    अभाज्य है []
    i के लिए सीमा + 1 में:
        यदि i >= 2 और छलनी[i]:
            अभाज्य है अभाज्य.जोड़ो(i)
    फल अभाज्य

अभाज्य_50 है अभाज्य_छलनी(50)
जाँचो("अभाज्य 50 तक गिनती", अभाज्य_50.लम्बाई(), 15)
जाँचो("पहला अभाज्य", अभाज्य_50[0], 2)
जाँचो("अंतिम अभाज्य <=50", अभाज्य_50[14], 47)

# Binary search
विधि द्विआधारी_खोज(सूची3, लक्ष्य):
    बायाँ है 0
    दायाँ है सूची3.लम्बाई() - 1
    जब तक बायाँ <= दायाँ:
        मध्य है (बायाँ + दायाँ) / 2
        यदि सूची3[गोल(मध्य)] बराबर लक्ष्य:
            फल गोल(मध्य)
        अन्यथा यदि सूची3[गोल(मध्य)] से कम लक्ष्य:
            बायाँ है गोल(मध्य) + 1
        अन्यथा:
            दायाँ है गोल(मध्य) - 1
    फल -1

क्रमित है [2, 5, 8, 12, 16, 23, 38, 56, 72, 91]
जाँचो("द्विआधारी खोज 23", द्विआधारी_खोज(क्रमित, 23), 5)
जाँचो("द्विआधारी खोज 2", द्विआधारी_खोज(क्रमित, 2), 0)
जाँचो("द्विआधारी खोज नहीं", द्विआधारी_खोज(क्रमित, 99), -1)

# QuickSort (functional style)
विधि त्वरित_क्रम(सूची4):
    यदि सूची4.लम्बाई() <= 1:
        फल सूची4
    धुरी है सूची4[0]
    छोटे है छानो(सूची4, लाम्डा(x): x से कम धुरी)
    बड़े है छानो(सूची4, लाम्डा(x): x से अधिक धुरी)
    बराबर2 है छानो(सूची4, लाम्डा(x): x बराबर धुरी)
    फल त्वरित_क्रम(छोटे) + बराबर2 + त्वरित_क्रम(बड़े)

अव्यवस्थित है [64, 34, 25, 12, 22, 11, 90, 1, 55, 3]
क्रमित2 है त्वरित_क्रम(अव्यवस्थित)
जाँचो("QuickSort[0]", क्रमित2[0], 1)
जाँचो("QuickSort[5]", क्रमित2[5], 25)
जाँचो("QuickSort[9]", क्रमित2[9], 90)
जाँचो("QuickSort लम्बाई", क्रमित2.लम्बाई(), 10)

# Fibonacci with memoization (dict cache)
याददाश्त है {0: 0, 1: 1}

विधि फिबो_याद(न3):
    वैश्विक याददाश्त
    यदि न3 से कम 0:
        फल 0
    k3 के लिए याददाश्त में:
        यदि वाक्य(k3) बराबर वाक्य(न3):
            फल याददाश्त[k3]
    परिणाम3 है फिबो_याद(न3 - 1) + फिबो_याद(न3 - 2)
    याददाश्त[न3] है परिणाम3
    फल परिणाम3

जाँचो("फिबो याद 10", फिबो_याद(10), 55)
जाँचो("फिबो याद 15", फिबो_याद(15), 610)

