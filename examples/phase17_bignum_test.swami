# Phase 17 — Big integers (भारत.बड़ी)
आयात भारत.बड़ी

बताओ "== 1. addition beyond f64 precision =="
# 2^53 = 9007199254740992; add 1 — f64 can't, bignum can
अ है महा_जोड़("9007199254740992", "1")
बताओ अ                          # 9007199254740993
जाँचो अ बराबर "9007199254740993", "बड़ा जोड़ गलत"

बताओ "== 2. huge multiplication =="
ब है महा_गुणा("123456789123456789", "987654321987654321")
बताओ ब                          # 121932631356500531347203169112635269
जाँचो ब बराबर "121932631356500531347203169112635269", "गुणा गलत"

बताओ "== 3. subtraction with sign =="
बताओ महा_घटा("100", "250")      # -150
जाँचो महा_घटा("100", "250") बराबर "-150", "घटा गलत"

बताओ "== 4. division and remainder =="
बताओ महा_भाग("100000000000000000000", "7")   # 14285714285714285714
बताओ महा_शेष("100000000000000000000", "7")   # 2
जाँचो महा_भाग("100", "7") बराबर "14", "भाग गलत"
जाँचो महा_शेष("100", "7") बराबर "2", "शेष गलत"

बताओ "== 5. power =="
बताओ महा_घात("2", 100)          # 1267650600228229401496703205376
जाँचो महा_घात("2", 64) बराबर "18446744073709551616", "घात गलत"

बताओ "== 6. factorial =="
बताओ महा_भाज्य(30)              # 265252859812191058636308480000000
जाँचो महा_भाज्य(20) बराबर "2432902008176640000", "भाज्य गलत"
जाँचो महा_भाज्य(0) बराबर "1", "0! गलत"

बताओ "== 7. compare =="
जाँचो महा_तुलना("999999999999999999", "1000000000000000000") बराबर -1, "तुलना< गलत"
जाँचो महा_तुलना("5", "5") बराबर 0, "तुलना= गलत"
जाँचो महा_तुलना("-3", "-7") बराबर 1, "तुलना(neg) गलत"

बताओ ""
बताओ "सब परीक्षण पास ✓"
