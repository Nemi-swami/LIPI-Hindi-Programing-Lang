# Phase 17 — भारत.कूट (hash + base64) परीक्षण — ज्ञात test vectors
आयात भारत.कूट

बताओ "== 1. sha256 — ज्ञात vectors =="
बताओ sha256("")
बताओ sha256("abc")
बताओ sha256("The quick brown fox jumps over the lazy dog")

बताओ "== 2. md5 — ज्ञात vectors =="
बताओ md5("")
बताओ md5("abc")
बताओ md5("The quick brown fox jumps over the lazy dog")

बताओ "== 3. base64 कूट =="
बताओ base64_कूट("Man")
बताओ base64_कूट("hello")
बताओ base64_कूट("he")
बताओ base64_कूट("h")
बताओ base64_कूट("")

बताओ "== 4. base64 खोलो =="
बताओ base64_खोलो("TWFu")
बताओ base64_खोलो("aGVsbG8=")

बताओ "== 5. देवनागरी round trip =="
मूल है "नमस्ते भारत! १२३"
कूटित है base64_कूट(मूल)
बताओ कूटित
यदि base64_खोलो(कूटित) बराबर मूल:
    बताओ "round trip सही"

बताओ "== 6. देवनागरी hash स्थिरता =="
यदि sha256("नमस्ते") बराबर sha256("नमस्ते"):
    बताओ "sha256 स्थिर"
बताओ sha256("नमस्ते")

बताओ "== 7. त्रुटियाँ =="
कोशिश:
    base64_खोलो("abc")
पकड़ो त्रुटि:
    बताओ "पकड़ा: " + त्रुटि
कोशिश:
    base64_खोलो("a$==")
पकड़ो त्रुटि:
    बताओ "पकड़ा: " + त्रुटि
कोशिश:
    sha256(42)
पकड़ो त्रुटि:
    बताओ "पकड़ा: " + त्रुटि

बताओ "== सम्पूर्ण =="
