# Phase 18 H2 — भारत.रेखीय (vectors, matrices, quaternions)
आयात भारत.रेखीय

बताओ "== 1. vectors =="
जाँचो बिंदु_गुणन([1, 2, 3], [4, 5, 6]) बराबर 32, "dot गलत"
जाँचो परिमाण([3, 4]) बराबर 5, "norm गलत"
जाँचो कोण_गुणन([1, 0, 0], [0, 1, 0]) बराबर [0, 0, 1], "cross गलत"
जाँचो सदिश_योग([1, 2], [3, 4]) बराबर [4, 6], "vec add गलत"
जाँचो दूरी([0, 0], [3, 4]) बराबर 5, "distance गलत"
बताओ सामान्य([3, 4])              # [0.6, 0.8]

बताओ "== 2. matrices =="
A है [[1, 2], [3, 4]]
B है [[5, 6], [7, 8]]
बताओ आव्यूह_गुणन(A, B)            # [[19, 22], [43, 50]]
जाँचो आव्यूह_गुणन(A, B) बराबर [[19, 22], [43, 50]], "matmul गलत"
जाँचो परिवर्त(A) बराबर [[1, 3], [2, 4]], "transpose गलत"
जाँचो सारणिक(A) बराबर -2, "det गलत"
जाँचो तत्समक(2) बराबर [[1, 0], [0, 1]], "identity गलत"

बताओ "== 3. inverse (A · A⁻¹ = I) =="
Ainv है प्रतिलोम(A)
उत्पाद है आव्यूह_गुणन(A, Ainv)
जाँचो निरपेक्ष(उत्पाद[0][0] - 1) से कम 0.0001, "I[0][0] गलत"
जाँचो निरपेक्ष(उत्पाद[0][1]) से कम 0.0001, "I[0][1] गलत"
जाँचो निरपेक्ष(उत्पाद[1][0]) से कम 0.0001, "I[1][0] गलत"
जाँचो निरपेक्ष(उत्पाद[1][1] - 1) से कम 0.0001, "I[1][1] गलत"
बताओ "A·A⁻¹ = I सत्यापित ✓"

बताओ "== 4. quaternions (attitude) =="
# identity quaternion rotates nothing
पहचान है [1, 0, 0, 0]
जाँचो चतुष्क_घुमाव(पहचान, [1, 2, 3]) बराबर [1, 2, 3], "identity rotation गलत"

# euler → quaternion → euler round-trip (90° yaw)
आधा_पाई है पाई / 2
q है कोण_से_चतुष्क(0, 0, आधा_पाई)
कोण है चतुष्क_से_कोण(q)
# yaw should be ~π/2
जाँचो निरपेक्ष(कोण[2] - आधा_पाई) से कम 0.001, "euler round-trip गलत"
बताओ "yaw बहाल: सही ✓"

# 90° yaw rotates x-axis [1,0,0] to ~[0,1,0]
घुमा है चतुष्क_घुमाव(q, [1, 0, 0])
जाँचो निरपेक्ष(घुमा[1] - 1) से कम 0.001, "rotation गलत"
बताओ "x→y घुमाव सही ✓"

बताओ ""
बताओ "सब परीक्षण पास ✓"
