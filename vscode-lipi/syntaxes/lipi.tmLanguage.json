{
  "name": "LIPI",
  "scopeName": "source.lipi",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords-control" },
    { "include": "#keywords-declaration" },
    { "include": "#word-operators" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#self-variable" },
    { "include": "#function-call" },
    { "include": "#symbol-operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.lipi",
          "match": "#.*$"
        },
        {
          "name": "comment.line.danda.lipi",
          "match": "।[^।\\r\\n]*।"
        },
        {
          "name": "comment.line.danda.unclosed.lipi",
          "match": "।[^\\r\\n]*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.lipi",
          "begin": "\"\"\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.lipi" }
          },
          "end": "\"\"\"",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.lipi" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.lipi",
              "match": "\\\\."
            },
            { "include": "#string-interpolation" }
          ]
        },
        {
          "name": "string.quoted.double.lipi",
          "begin": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.lipi" }
          },
          "end": "\"",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.lipi" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.lipi",
              "match": "\\\\."
            },
            { "include": "#string-interpolation" }
          ]
        }
      ]
    },
    "string-interpolation": {
      "patterns": [
        {
          "name": "constant.other.placeholder.format.lipi",
          "match": "\\{\\}|\\{:[^{}\\r\\n]*\\}"
        },
        {
          "name": "meta.interpolation.lipi",
          "match": "(\\{)([^{}:\\r\\n]+)(\\})",
          "captures": {
            "1": { "name": "punctuation.definition.interpolation.begin.lipi" },
            "2": { "name": "variable.other.interpolated.lipi" },
            "3": { "name": "punctuation.definition.interpolation.end.lipi" }
          }
        }
      ]
    },
    "keywords-control": {
      "patterns": [
        {
          "name": "keyword.control.lipi",
          "match": "(?<![\\p{L}\\p{M}_.])(अन्यथा यदि|जब तक|बंद करो|बार करो|के लिए|यदि|अन्यथा|अन्य|तो|में|अगला|कोशिश|पकड़ो|मिलाओ|फल)(?![\\p{L}\\p{M}_])"
        }
      ]
    },
    "keywords-declaration": {
      "patterns": [
        {
          "name": "storage.type.lipi",
          "match": "(?<![\\p{L}\\p{M}_.])(शुद्ध विधि|विधि|वर्ग|विकल्प|लाम्डा|आयात|वैश्विक|स्थिर|शुद्ध|जाँचो)(?![\\p{L}\\p{M}_])"
        }
      ]
    },
    "word-operators": {
      "patterns": [
        {
          "name": "keyword.operator.word.lipi",
          "match": "(?<![\\p{L}\\p{M}_.])(से अधिक|से कम|नहीं_है|में_है|बराबर|और|या|नहीं|है)(?![\\p{L}\\p{M}_])"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.lipi",
          "match": "(?<![\\p{L}\\p{M}_.])(सत्य|असत्य|पाई|अनंत|ऋण_अनंत)(?![\\p{L}\\p{M}_])"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.lipi",
          "match": "(?<![\\p{L}\\p{M}\\p{N}_])[0-9०-९]+(?:\\.[0-9०-९]+)?(?:\\s+(?:लाख|करोड़)(?![\\p{L}\\p{M}_]))?"
        }
      ]
    },
    "self-variable": {
      "patterns": [
        {
          "name": "variable.language.self.lipi",
          "match": "(?<![\\p{L}\\p{M}_.])यह(?![\\p{L}\\p{M}_])"
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "name": "entity.name.function.lipi",
          "match": "(?<![\\p{L}\\p{M}\\p{N}_])[\\p{L}_][\\p{L}\\p{M}\\p{N}_]*(?=\\s*\\()"
        }
      ]
    },
    "symbol-operators": {
      "patterns": [
        {
          "name": "keyword.operator.lipi",
          "match": "<<|>>|<=|>=|==|!=|//|\\*|[-+/%&|^~<>=:]"
        }
      ]
    }
  }
}
