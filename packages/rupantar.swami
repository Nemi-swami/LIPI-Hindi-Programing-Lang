। रूपांतर — unit conversions ।

विधि सेल्सियस_से_फारेनहाइट(स):
    फल स * 9 / 5 + 32

विधि फारेनहाइट_से_सेल्सियस(फ):
    फल (फ - 32) * 5 / 9

विधि किमी_से_मील(किमी):
    फल किमी * 0.621371

विधि मील_से_किमी(मील):
    फल मील * 1.609344

विधि किग्रा_से_पाउंड(किग्रा):
    फल किग्रा * 2.2046226

विधि डिग्री_से_रेडियन(डि):
    फल डि * पाई / 180
