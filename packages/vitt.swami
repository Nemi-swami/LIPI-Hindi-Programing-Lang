। वित्त — finance helpers (Indian context) ।

विधि जीएसटी_जोड़ो(राशि, दर):
    फल राशि + राशि * दर / 100

विधि जीएसटी_राशि(राशि, दर):
    फल राशि * दर / 100

विधि साधारण_ब्याज(मूल, दर, वर्ष):
    फल मूल * दर * वर्ष / 100

विधि चक्रवृद्धि(मूल, दर, वर्ष):
    फल मूल * घात(1 + दर / 100, वर्ष) - मूल

विधि ईएमआई(मूल, वार्षिक_दर, महीने):
    r है वार्षिक_दर / 1200
    यदि r बराबर 0:
        फल मूल / महीने
    प है घात(1 + r, महीने)
    फल मूल * r * प / (प - 1)
