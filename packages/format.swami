। स्वरूपण — number & text formatting helpers ।

विधि दो_दशमलव(न):
    फल स्वरूप("{:.2}", न)

विधि प्रतिशत(अंश, कुल):
    यदि कुल बराबर 0:
        फल "0%"
    फल स्वरूप("{:.1}", अंश * 100 / कुल) + "%"

विधि भारतीय_अंक(न):
    फल स्वरूप("{:,}", न)

विधि रुपये(न):
    फल स्वरूप("{:₹}", न)

विधि शीर्षक_रेखा(वाक्य, वर्ण):
    रेखा है ""
    i के लिए वाक्य.लम्बाई() में:
        रेखा है रेखा + वर्ण
    फल वाक्य + "\n" + रेखा
